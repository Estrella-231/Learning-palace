{
  "models": {
    "default": "minimax-anthropic",
    "minimax-anthropic": {
      "provider": "anthropic",
      "model": "MiniMax-M2.5",
      "api_key": "${LP_API_KEY}",
      "base_url": "https://api.minimaxi.com/anthropic"
    },
    "minimax": {
      "provider": "openai-compatible",
      "model": "MiniMax-M1",
      "api_key": "${MINIMAX_API_KEY}",
      "base_url": "https://api.minimax.chat/v1"
    },
    "claude": {
      "provider": "anthropic",
      "model": "claude-sonnet-4-6",
      "api_key": "${ANTHROPIC_API_KEY}"
    },
    "openai": {
      "provider": "openai",
      "model": "gpt-4o",
      "api_key": "${OPENAI_API_KEY}"
    },
    "openrouter": {
      "provider": "openai-compatible",
      "model": "openai/gpt-4o",
      "api_key": "${OPENROUTER_API_KEY}",
      "base_url": "https://openrouter.ai/api/v1"
    },
    "deepseek": {
      "provider": "openai-compatible",
      "model": "deepseek-chat",
      "api_key": "${DEEPSEEK_API_KEY}",
      "base_url": "https://api.deepseek.com/v1"
    }
  },
  "extraction": {
    "model": "minimax-anthropic",
    "temperature": 0.3
  },
  "embedding": {
    "model": "text-embedding-3-small",
    "provider": "openai",
    "api_key": "${OPENAI_API_KEY}"
  },
  "database_url": "postgresql+asyncpg://postgres:postgres@localhost:5432/learning_palace",
  "database_sync_url": "postgresql://postgres:postgres@localhost:5432/learning_palace"
}
